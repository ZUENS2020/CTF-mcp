# Build-time proxy for containers (inside Docker network)
HTTP_PROXY=http://host.docker.internal:7891
HTTPS_PROXY=http://host.docker.internal:7891
NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Optional: tune Kali apt build behavior
KALI_MIRROR=http://http.kali.org/kali
APT_RETRIES=8
APT_TIMEOUT=30
