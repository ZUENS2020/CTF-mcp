FROM rust:1.87-slim AS bore-builder

RUN cargo install --locked bore-cli

FROM python:3.12-slim

WORKDIR /app

COPY --from=bore-builder /usr/local/cargo/bin/bore /usr/local/bin/bore

COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY app /app/app

RUN mkdir -p /app/data && bore --help >/dev/null

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
